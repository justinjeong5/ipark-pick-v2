# Copy this file to ".env" and fill real values.
#   cp env.example .env
# `.env` is git-ignored — credentials never leave your machine.

# === Naver accounts (cookie-based auth — passwords NOT used at runtime) ===
# Each account contributes one comment. Comment text is the exact string
# the bot will post, typically "이름+생년월일4자리" (예: 정창우1125).
# No spaces, no line breaks, no extra punctuation.
NAVER_ACCOUNT_1_ID=
NAVER_ACCOUNT_1_COMMENT=

NAVER_ACCOUNT_2_ID=
NAVER_ACCOUNT_2_COMMENT=

NAVER_ACCOUNT_3_ID=
NAVER_ACCOUNT_3_COMMENT=

# === Target cafe ===
# CAFE_URL is informational only — runtime uses CLUB_ID for every URL.
TARGET_CAFE_URL=https://cafe.naver.com/<your-cafe-slug>
# Cafe internal id; found in any article URL: /cafes/<CLUB_ID>/articles/...
TARGET_CLUB_ID=
# Menu id used when constructing the comment-target article URL.
# 0 = "all articles" (safe default; the cafe usually accepts any menu id here).
TARGET_MENU_ID=0
# Menu id board_finder scrolls when looking for today's post.
# 0 = "all articles" — recommended.
TARGET_LIST_MENU_ID=0
# Article id is auto-discovered every Thursday by board_finder; leave empty.
TARGET_ARTICLE_ID=

# === Telegram (reuse an existing bot — DO NOT mint a new token if you have one) ===
# Bot token from @BotFather, format like "12345:AAAA...".
TELEGRAM_BOT_TOKEN=
# Private supergroup: URL "t.me/c/<id>" -> chat_id is "-100<id>".
# Public group/channel: numeric id from getUpdates, or "@channelname".
TELEGRAM_CHAT_ID=

# === Runtime ===
# 'true'  → Chromium window visible (디버깅·첫 로그인 검증용)
# 'false' → headless background (운영 권장)
HEADFUL=false
# Polling window for comment box activation, in seconds (1분 — 운영자 오차 흡수).
COMMENT_POLL_TIMEOUT=60
