# Copy this file to ".env" and fill in real values.
#   cp env.example .env

# --- Naver accounts (for now, single account for verification) ---
# Account 1
NAVER_ACCOUNT_1_ID=
NAVER_ACCOUNT_1_COMMENT=

# Account 2 (used in later phase)
NAVER_ACCOUNT_2_ID=
NAVER_ACCOUNT_2_COMMENT=

# Account 3 (used in later phase)
NAVER_ACCOUNT_3_ID=
NAVER_ACCOUNT_3_COMMENT=

# --- Target post (test cafe for now) ---
TARGET_CAFE_URL=https://cafe.naver.com/redn47ad
TARGET_CLUB_ID=30796368
TARGET_ARTICLE_ID=21
TARGET_MENU_ID=2

# --- Telegram (used in later phase) ---
# Reuse an existing bot token; just invite that bot to the channel.
TELEGRAM_BOT_TOKEN=
# Private supergroup: URL "t.me/c/<id>" -> chat_id is "-100<id>"
TELEGRAM_CHAT_ID=

# --- Runtime ---
# 'true' shows the browser window (useful for first login & debugging)
HEADFUL=false
# Polling window for comment box activation, in seconds
COMMENT_POLL_TIMEOUT=60
