# 이 파일을 .env로 복사한 뒤 실제 값을 채우세요.
#   cp env.example .env
# .env 는 git에 올라가지 않습니다.

# === 네이버 계정 (3개 모두 필수) ===
# 댓글 텍스트 형식: "이름 + 생년월일 4자리" (예: 정창우1125)
# 띄어쓰기·줄바꿈·특수문자 없이 정확히.
NAVER_ACCOUNT_1_ID=
NAVER_ACCOUNT_1_COMMENT=

NAVER_ACCOUNT_2_ID=
NAVER_ACCOUNT_2_COMMENT=

NAVER_ACCOUNT_3_ID=
NAVER_ACCOUNT_3_COMMENT=

# === 카페 정보 (필수) ===
# 카페 게시글 URL의 /cafes/<숫자> 부분
TARGET_CLUB_ID=
# 게시판 자동 탐색용 메뉴 ID. 0 = 전체글 (권장)
TARGET_LIST_MENU_ID=0

# === 텔레그램 (필수) ===
# 기존 봇 토큰 그대로 재사용. BotFather 발급 형식: "12345:AAAA..."
TELEGRAM_BOT_TOKEN=
# 비공개 그룹: t.me/c/<id> 주소면 chat_id 는 "-100<id>" 형태
TELEGRAM_CHAT_ID=

# === 실행 옵션 (선택) ===
# true  = 브라우저 창 표시 (디버깅·첫 로그인 검증용)
# false = 백그라운드 실행 (운영 권장)
HEADFUL=false
# 댓글창 폴링 타임아웃 (초). 1분이면 충분.
COMMENT_POLL_TIMEOUT=60
